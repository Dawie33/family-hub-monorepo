# Chargé par le backend NestJS (envFilePath: '../../.env' depuis apps/backend/)
# Copier en .env dans ce répertoire (apps/family-hub/.env)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application
PORT=3003
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3002
API_BASE_URL=http://localhost:3003

# Intégration Recipe AI (Next.js fullstack, port 3005)
RECIPE_AI_URL=http://localhost:3005

# Intégration Training Camp (NestJS backend, port 3001)
TRAINING_CAMP_API_URL=http://localhost:3001/api
TRAINING_CAMP_EMAIL=your-training-camp-account@email.com
TRAINING_CAMP_PASSWORD=your-training-camp-password

# Zep (mémoire conversationnelle)
ZEP_API_KEY=
