# Chargé par le backend NestJS (envFilePath: '../../.env' depuis apps/backend/)
# Copier en .env dans ce répertoire (apps/family-hub/.env)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application
PORT=3003
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3002
API_BASE_URL=http://localhost:3003

# Intégrations externes
RECIPE_AI_URL=http://localhost:3005

# Zep (mémoire conversationnelle)
ZEP_API_KEY=
