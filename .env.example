# ============================================================
# FAMILY-HUB MONOREPO — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- pgAdmin (optionnel, profil: tools) ---
PGADMIN_EMAIL=admin@localhost.com
PGADMIN_PASSWORD=admin

# ============================================================
# TRAINING-CAMP
# ============================================================
TC_DB_NAME=training_camp

# Frontend (Next.js) — port 3000
TC_FRONTEND_PORT=3000

# Backend (NestJS) — port 3001
TC_BACKEND_PORT=3001
TC_NODE_ENV=development

# ============================================================
# FAMILY-HUB
# ============================================================
# Base de données : Supabase CLI local (npx supabase start depuis apps/family-hub)
# Les clés sont générées automatiquement — voir apps/family-hub/.env

# Frontend (Next.js) — port 3002
FH_FRONTEND_PORT=3002

# Backend (NestJS) — port 3003
FH_BACKEND_PORT=3003
