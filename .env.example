# ============================================================
# FAMILY-HUB MONOREPO — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- PostgreSQL (partagé entre les apps) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- pgAdmin (optionnel, profil: tools) ---
PGADMIN_EMAIL=admin@localhost.com
PGADMIN_PASSWORD=admin

# ============================================================
# TRAINING-CAMP
# ============================================================
TC_DB_NAME=training_camp
TC_DB_URL=postgresql://postgres:changeme@localhost:5432/training_camp

# Frontend (Next.js) — port 3001
TC_FRONTEND_PORT=3001

# Backend (NestJS) — port 3002
TC_BACKEND_PORT=3002
TC_NODE_ENV=development

# ============================================================
# FAMILY-HUB
# ============================================================
FH_DB_NAME=ai_agent_platform
FH_DB_URL=postgresql://postgres:changeme@localhost:5432/ai_agent_platform

# Frontend (Next.js) — port 3003
FH_FRONTEND_PORT=3003

# Backend (NestJS) — port 3004
FH_BACKEND_PORT=3004

# Redis
FH_REDIS_HOST=localhost
FH_REDIS_PORT=6379

# Supabase
FH_SUPABASE_URL=https://your-project.supabase.co
FH_SUPABASE_ANON_KEY=your-anon-key
FH_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude)
FH_ANTHROPIC_API_KEY=sk-ant-...

# Firebase
FH_FIREBASE_PROJECT_ID=your-project-id
FH_FIREBASE_PRIVATE_KEY=your-private-key
FH_FIREBASE_CLIENT_EMAIL=your-client-email

# Google APIs
FH_GOOGLE_CLIENT_ID=your-client-id
FH_GOOGLE_CLIENT_SECRET=your-client-secret

# Twilio (SMS)
FH_TWILIO_ACCOUNT_SID=your-account-sid
FH_TWILIO_AUTH_TOKEN=your-auth-token
FH_TWILIO_PHONE_NUMBER=+1234567890

# (recipe-ai intégré dans family-hub — plus d'app séparée)
